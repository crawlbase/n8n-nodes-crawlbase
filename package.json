{
  "name": "@crawlbase/n8n-nodes-crawlbase",
  "version": "1.0.6",
  "description": "Crawlbase node for n8n — crawl web pages, scrape public information, bypass CAPTCHAs, run automations",
  "license": "MIT",
  "homepage": "https://github.com/crawlbase/n8n-nodes-crawlbase",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "crawlbase",
    "crawling",
    "scraping",
    "scraper",
    "captcha"
  ],
  "author": {
    "name": "Crawlbase",
    "email": "info@crawlbase.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/crawlbase/n8n-nodes-crawlbase"
  },
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs'),cp=require('child_process');if(fs.existsSync('node_modules/patch-package'))cp.execSync('node node_modules/patch-package/index.js',{stdio:'inherit'});\"",
    "copy:icons": "copyfiles -u 1 \"icons/*.svg\" dist/icons",
    "build": "npm run build:tsc && npm run copy:icons",
    "build:watch": "node node_modules/typescript/bin/tsc --watch",
    "build:tsc": "node node_modules/typescript/bin/tsc",
    "test": "tsx --test nodes/Crawlbase/crawlbaseApi.helpers.test.ts",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist",
    "README.md",
    "example-workflow.json"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [
      "dist/credentials/CrawlbaseApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Crawlbase/Crawlbase.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/eslint-plugin-community-nodes": "0.13.0",
    "@n8n/node-cli": "0.28.0",
    "copyfiles": "^2.4.1",
    "eslint": "^10.3.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "engines": {
    "node": ">=22.16"
  },
  "overrides": {
    "change-case": "4.1.2"
  }
}
