{
  "name": "n8n-nodes-crawlbase",
  "version": "0.1.0",
  "description": "Crawlbase node for n8n — crawl web pages with native credentials and the Crawling API",
  "license": "MIT",
  "homepage": "https://github.com/crawlbase/crawlbase-node#readme",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "crawlbase",
    "crawling",
    "scraping",
    "scraper"
  ],
  "author": { "name": "Crawlbase", "email": "info@crawlbase.com" },
  "repository": {
    "type": "git",
    "url": "https://github.com/crawlbase/crawlbase-node.git",
    "directory": "n8n"
  },
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc && node -e \"const fs=require('fs'); const p='dist/icons'; fs.mkdirSync(p,{recursive:true}); fs.copyFileSync('icons/crawlbase.svg', p+'/crawlbase.svg'); fs.copyFileSync('icons/crawlbase.dark.svg', p+'/crawlbase.dark.svg');\"",
    "build:watch": "node node_modules/typescript/bin/tsc --watch",
    "build:tsc": "node node_modules/typescript/bin/tsc",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": ["dist", "README.md", "example-workflow.json"],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": ["dist/credentials/CrawlbaseApi.credentials.js"],
    "nodes": ["dist/nodes/Crawlbase/Crawlbase.node.js"]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "^9.32.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2"
  },
  "peerDependencies": { "n8n-workflow": "*" },
  "engines": { "node": ">=22.16" },
  "overrides": { "change-case": "4.1.2" }
}
